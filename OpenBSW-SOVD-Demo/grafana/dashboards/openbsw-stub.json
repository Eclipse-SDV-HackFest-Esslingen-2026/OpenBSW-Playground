          },
          {
            "matcher": { "id": "byName", "options": "Confirmed" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background-solid"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "true": { "text": "YES", "color": "orange" }, "false": { "text": "NO", "color": "green" } } }
                ]
              },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Severity" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-text"
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "critical": { "text": "🔴 CRITICAL", "color": "red" }, "high": { "text": "🟠 HIGH", "color": "orange" }, "medium": { "text": "🟡 MEDIUM", "color": "yellow" }, "low": { "text": "🟢 LOW", "color": "green" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-text" },
              { "id": "unit", "value": "hex0x" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Active", "desc": true }],
        "footer": { "show": false }
