              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "true": { "text": "⚠ ACTIVE", "color": "red" }, "false": { "text": "OK", "color": "green" } } }
                ]
              },
              { "id": "custom.width", "value": 90 }
