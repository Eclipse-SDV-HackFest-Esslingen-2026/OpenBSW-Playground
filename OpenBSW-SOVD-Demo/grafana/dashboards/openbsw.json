      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto", "filterable": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Active" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background-solid" },
              { "id": "mappings", "value": [{ "type": "value", "options": { "true": { "text": "⚠ ACTIVE", "color": "red" }, "false": { "text": "OK", "color": "green" } } }] },
              { "id": "custom.width", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Confirmed" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background-solid" },
              { "id": "mappings", "value": [{ "type": "value", "options": { "true": { "text": "YES", "color": "orange" }, "false": { "text": "NO", "color": "green" } } }] },
              { "id": "custom.width", "value": 80 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Active", "desc": true }],
        "footer": { "show": false }
      }
